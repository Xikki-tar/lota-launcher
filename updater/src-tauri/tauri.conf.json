{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lota Launcher Updater",
  "version": "0.1.0",
  "identifier": "com.lota.launcher.updater",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LOTA Launcher",
        "width": 420,
        "height": 200,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
